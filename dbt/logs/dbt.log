[0m12:38:25.440007 [debug] [Thread-1 (]: On model.CryptoETL.daily_candle: /* {"app": "dbt", "dbt_version": "1.11.4", "profile_name": "duckdb", "target_name": "dev", "node_id": "model.CryptoETL.daily_candle"} */

  
    
    

    create  table
      "crypto_vault"."main"."daily_candle__dbt_tmp"
  
    as (
      -- models/daily_candles.sql




WITH raw_data AS (
    SELECT 
        epoch_ms(timestamp) as price_timestamp,
        price
    FROM raw_ethereum_prices
),

daily_prices AS (
    SELECT 
        date_trunc('day', price_timestamp) as day,
        price,
        price_timestamp,
        ROW_NUMBER() OVER (PARTITION BY date_trunc('day', price_timestamp) ORDER BY price_timestamp ASC) as row_asc,
        ROW_NUMBER() OVER (PARTITION BY date_trunc('day', price_timestamp) ORDER BY price_timestamp DESC) as row_desc
    FROM raw_data
),


final AS (
    SELECT 
        day,
        MAX(CASE WHEN row_asc = 1 THEN price END) as open_price,
        MAX(price) as high_price,
        MIN(price) as low_price,
        MAX(CASE WHEN row_desc = 1 THEN price END) as close_price
    FROM daily_prices
    GROUP BY 1
)

SELECT 
    *,
    ROUND(((close_price - open_price) / open_price) * 100, 2) as daily_change_pct
FROM final
ORDER BY day DESC
    );
  
  
